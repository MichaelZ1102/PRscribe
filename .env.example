# ====================
# 服务配置
# ====================
PORT=3000
NODE_ENV=development

# ====================
# GitHub App 凭证
# ====================
GITHUB_APP_ID=your_app_id_here
GITHUB_PRIVATE_KEY="[REDACTED PRIVATE KEY]"
GITHUB_WEBHOOK_SECRET=your_we...ec

# ====================
# LLM API（支持任意 OpenAI 兼容 API）
# ====================
# API Key（必填）
LLM_API_KEY=your-groq-api-key

# Base URL — 按你用的服务填
# OpenAI 官方:    https://api.openai.com/v1        （默认）
# OpenRouter:     https://openrouter.ai/api/v1
# DeepSeek:       https://api.deepseek.com/v1
# Groq:           https://api.groq.com/openai/v1
# Together AI:    https://api.together.xyz/v1
# 其他兼容 API:   填对应的 base_url
LLM_BASE_URL=https://api.groq.com/openai/v1

# 模型名（按你用的服务填）
# OpenAI:        gpt-4o-mini, gpt-4o
# OpenRouter:    openai/gpt-4o-mini, anthropic/claude-sonnet-4
# DeepSeek:      deepseek-chat
# Groq:          llama-3.3-70b-versatile
LLM_MODEL=llama-3.3-70b-versatile

# 生成参数
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2000

# ====================
# 队列 (Upstash Redis)
# ====================
REDIS_URL=redis://default:***@xxx.upstash.io:6379

# ====================
# 监控（可选）
# ====================
# SENTRY_DSN=***
